# Docker Compose Environment Variables for Backend Developers
# Copy this file to .env.docker and adjust as needed
#
# Usage: docker compose --env-file .env.docker up

# ============================================
# Backend Connection (Java Server)
# ============================================
# The URL where your local Java backend is running
# For Linux: host.docker.internal resolves to the host machine (Docker 20.10+)
BACKEND_URL=http://host.docker.internal:8086

# The hostname/IP for direct backend connections (without protocol)
BACKEND_HOST=host.docker.internal

# ============================================
# Alternative: Use Host IP Address
# ============================================
# If host.docker.internal doesn't work (Docker < 20.10), use your machine's IP:
# BACKEND_URL=http://172.17.0.1:8086
# BACKEND_HOST=172.17.0.1
#
# Find your IP with: ip addr show docker0 | grep -Po 'inet \K[\d.]+'

# ============================================
# OAuth2/OIDC Configuration
# ============================================
OIDC_ISSUER_URL=https://auth.onprem.agrp.dev/realms/atlasgroup
