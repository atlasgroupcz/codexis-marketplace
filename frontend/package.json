{
  "name": "codexis-marketplace-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "prebuild": "turbo boundaries && turbo prebuild",
    "boundaries": "turbo boundaries",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
