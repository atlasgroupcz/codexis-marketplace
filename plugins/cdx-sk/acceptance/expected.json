{
  "skills": [
    "cdx-sk:cdx-sk"
  ],
  "env_vars": [
    "CODEXIS_PUBLIC_SK_API_URL",
    "CODEXIS_USER_API_TOKEN"
  ],
  "post_install": [
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-sk"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-sk-link-rewriter"
    }
  ],
  "post_uninstall": [
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-sk"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-sk-link-rewriter"
    }
  ]
}
