  "apiDocsUrl": "https://beta.next.codexis.cz/rest/v3/api-docs",
  "fetchedAt": "2026-03-18T15:10:22Z",
  "cdxPatterns": [
    "cdx://doc/<DOC_ID>/meta",
    "cdx://cz_law/<NUM>/<YEAR>/meta"
  ],
  "operations": [
    {
      "path": "/rest/cdx-api/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Returns metadata for a document. The response contains source-specific metadata in the corresponding field (cr, sk, jd, es, eu, lt, vs, comment) based on the document type.",
      "operationId": "getDocumentMetadata",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document identifier",
          "required": true,
          "schema": {
            "type": "string"
          },
          "example": "CR13986_2026_01_01"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentMetadataResponse"
              }
            }
          }
        },
        "404": {
          "description": "Document not found",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentMetadataResponse"
              }
            }
          }
        }
      }
    },
    {
      "path": "/rest/cdx-api/cz_law/{lawNumber}/{lawYear}/meta",
      "method": "get",
      "summary": "Get Czech law metadata (by law number and year)",
      "description": "Resolves Czech legislation by law number/year (e.g. 262/2006 Sb.) to the current/nearest valid time version and returns its metadata. Same output format as GET /doc/{docId}/meta.",
      "operationId": "getCzLawMetadata",
      "parameters": [
        {
          "name": "lawNumber",
          "in": "path",
          "description": "Number of the law",
          "required": true,
          "schema": {
            "type": "string"
          },
          "example": 262
        },
        {
          "name": "lawYear",
          "in": "path",
          "description": "Year of the law",
          "required": true,
          "schema": {
            "type": "string"
          },
          "example": 2006
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentMetadataResponse"
              }
            }
          }
        },
        "404": {
          "description": "Law not found",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentMetadataResponse"
              }
            }
          }
        }
      }
    }
  ],
