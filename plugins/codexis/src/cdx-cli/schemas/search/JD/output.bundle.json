{
  "source": "JD",
  "kind": "output",
  "root": "JdSearchResponse",
  "apiDocsUrl": "https://beta.next.codexis.cz/rest/v3/api-docs",
  "fetchedAt": "2026-03-18T09:41:52Z",
  "components": {
    "JdSearchResponse": {
      "type": "object",
      "description": "Search response for Czech case law (JD) containing document data",
      "properties": {
        "results": {
          "type": "array",
          "description": "List of matching documents",
          "items": {
            "$ref": "#/components/schemas/JdSearchResultItem"
          }
        },
        "totalResults": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of matching documents"
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "description": "Offset of the first result"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "description": "Maximum number of results returned"
        }
      }
    },
    "JdSearchResultItem": {
      "type": "object",
      "description": "Single flattened JD search result item",
      "properties": {
        "docId": {
          "type": "string",
          "description": "Document ID",
          "example": "JD123456"
        },
        "docUrl": {
          "type": "string",
          "description": "Document text URL",
          "example": "cdx://doc/JD123456/text"
        },
        "docType": {
          "type": "string",
          "description": "Document type",
          "example": "Rozsudek"
        },
        "source": {
          "type": "string",
          "description": "Document source"
        },
        "city": {
          "type": "string",
          "description": "City",
          "example": "Brno"
        },
        "court": {
          "type": "string",
          "description": "Court name",
          "example": "Nejvyšší soud"
        },
        "createdDate": {
          "type": "string",
          "format": "date",
          "description": "Creation date"
        },
        "spZns": {
          "type": "array",
          "description": "Case numbers (spisové značky)",
          "items": {
            "type": "string"
          }
        },
        "cislaJednaci": {
          "type": "array",
          "description": "Reference numbers (čísla jednací)",
          "items": {
            "type": "string"
          }
        },
        "sbirkoveCislo": {
          "type": "string",
          "description": "Collection number (sbírkové číslo)"
        },
        "ecli": {
          "type": "string",
          "description": "ECLI identifier"
        },
        "legalSentence": {
          "type": "string",
          "description": "Legal sentence / summary"
        },
        "note": {
          "type": "string",
          "description": "Note"
        },
        "derogated": {
          "type": "boolean",
          "description": "Whether the decision has been derogated"
        },
        "snippet": {
          "type": "string",
          "description": "Search match snippet from document content (HTML)"
        },
        "title": {
          "type": "string",
          "description": "Search match snippet from document title (HTML)"
        }
      }
    }
  }
