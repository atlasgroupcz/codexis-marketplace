  "components": {
    "CdxSearchRequest": {
      "type": "object",
      "description": "Global CODEXIS search request",
      "properties": {
        "searchSortBy": {
          "type": "string",
          "description": "Sorting for global search",
          "enum": [
            "DATE",
            "RELEVANCE"
          ]
        },
        "query": {
          "type": "string",
          "description": "Fulltext search query. Supports space-separated terms, wildcards (*), and phrase search with double quotes. Write Czech characters directly (e.g., `požární ochrana`, `nájem bytu`). Do not use Unicode escapes.",
          "examples": [
            "požární ochrana \"nájem bytu\"",
            "smlouva o dílo",
            "vražda z afektu"
          ],
          "minLength": 1
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "default": 0,
          "description": "Offset of the first result (0-based)"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "default": 10,
          "description": "Number of results (1-50)"
        },
        "sortOrder": {
          "type": "string",
          "default": "DESC",
          "description": "Sort order for results",
          "enum": [
            "ASC",
            "DESC"
          ]
        },
        "commonSearchParameters": {
          "description": "Common search parameters (query, paging, sort order)"
        }
      },
      "required": [
        "commonSearchParameters",
        "query"
      ]
    }
  }
