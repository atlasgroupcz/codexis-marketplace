  "components": {
    "CommentSearchRequest": {
      "type": "object",
      "description": "Search request for Liberis commentaries",
      "properties": {
        "sort": {
          "type": "string",
          "description": "Sorting option",
          "enum": [
            "DATE",
            "NAME",
            "RELEVANCE"
          ]
        },
        "query": {
          "type": "string",
          "description": "Fulltext search query. Supports space-separated terms, wildcards (*), and phrase search with double quotes. Write Czech characters directly (e.g., `požární ochrana`, `nájem bytu`). Do not use Unicode escapes.",
          "examples": [
            "požární ochrana \"nájem bytu\"",
            "smlouva o dílo",
            "vražda z afektu"
          ],
          "minLength": 1
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "default": 0,
          "description": "Offset of the first result (0-based)"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "default": 10,
          "description": "Number of results (1-50)"
        },
        "sortOrder": {
          "type": "string",
          "default": "DESC",
          "description": "Sort order for results",
          "enum": [
            "ASC",
            "DESC"
          ]
        },
        "issuedFrom": {
          "type": "string",
          "format": "date",
          "description": "Issue date from",
          "example": "2020-01-01"
        },
        "issuedTo": {
          "type": "string",
          "format": "date",
          "description": "Issue date to",
          "example": "2023-12-31"
        },
        "relatedWithItem": {
          "type": "string",
          "description": "Related LCR docId to scope comments",
          "example": "CR13986"
        },
        "relatedWithItemPart": {
          "type": "string",
          "description": "Related doc part (use with relatedWithItem)",
          "example": "paragraf89"
        }
      },
      "required": [
        "query"
      ]
    }
  }
