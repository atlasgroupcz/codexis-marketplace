  "components": {
    "VsSearchRequest": {
      "type": "object",
      "description": "Search request for contract templates (VS)",
      "properties": {
        "sort": {
          "type": "string",
          "description": "Sorting option",
          "enum": [
            "DATE",
            "NAME",
            "RELEVANCE"
          ]
        },
        "query": {
          "type": "string",
          "description": "Fulltext search query. Supports space-separated terms, wildcards (*), and phrase search with double quotes. Write Czech characters directly (e.g., `požární ochrana`, `nájem bytu`). Do not use Unicode escapes.",
          "examples": [
            "požární ochrana \"nájem bytu\"",
            "smlouva o dílo",
            "vražda z afektu"
          ],
          "minLength": 1
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "default": 0,
          "description": "Offset of the first result (0-based)"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "default": 10,
          "description": "Number of results (1-50)"
        },
        "sortOrder": {
          "type": "string",
          "default": "DESC",
          "description": "Sort order for results",
          "enum": [
            "ASC",
            "DESC"
          ]
        },
        "autor": {
          "type": "array",
          "description": "Facet field 'autor'",
          "example": [
            "AK Sokol Novák tdpA",
            "Linde Praha a. s."
          ],
          "items": {
            "type": "string"
          }
        },
        "kategorie": {
          "type": "array",
          "description": "Facet field 'kategorie'",
          "example": [
            "Pracovní právo (vzory dle zákoníku práce)",
            "Občanské právo hmotné (vzory dle občanského zákoníku)"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "query"
      ]
    }
  }
