{
  "source": "CR",
  "kind": "output",
  "root": "CrSearchResponse",
  "apiDocsUrl": "https://beta.next.codexis.cz/rest/v3/api-docs",
  "fetchedAt": "2026-03-18T09:41:52Z",
  "components": {
    "CrSearchResponse": {
      "type": "object",
      "description": "Search response for Czech legislation (CR) with flattened result items",
      "properties": {
        "results": {
          "type": "array",
          "description": "List of matching documents",
          "items": {
            "$ref": "#/components/schemas/CrSearchResultItem"
          }
        },
        "totalResults": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of matching documents"
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "description": "Offset of the first result"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "description": "Maximum number of results returned"
        }
      }
    },
    "CrSearchResultItem": {
      "type": "object",
      "description": "Single flattened CR search result item",
      "properties": {
        "docId": {
          "type": "string",
          "description": "Document ID (timecut ID)",
          "example": "CR123456_2024_01_01"
        },
        "docUrl": {
          "type": "string",
          "description": "Document text URL (may include ?part=... for section-level hits)",
          "example": "cdx://doc/CR123456_2024_01_01/text?part=paragraf1"
        },
        "docNumber": {
          "type": "string",
          "description": "Document number",
          "example": "262/2006"
        },
        "docType": {
          "type": "string",
          "description": "Document type",
          "example": "Zákon"
        },
        "source": {
          "type": "string",
          "description": "Source",
          "example": "Sbírka zákonů"
        },
        "castka": {
          "type": "string",
          "description": "Collection issue (částka)",
          "example": "84/2006"
        },
        "schvaleno": {
          "type": "string",
          "format": "date",
          "description": "Approval date (schváleno)"
        },
        "platnyod": {
          "type": "string",
          "format": "date",
          "description": "Valid from date (platný od)"
        },
        "ucinnyod": {
          "type": "string",
          "format": "date",
          "description": "Effective from date (účinný od)"
        },
        "zruseno": {
          "type": "string",
          "format": "date",
          "description": "Cancelled date (zrušeno)"
        },
        "note": {
          "type": "string",
          "description": "Note"
        },
        "snippet": {
          "type": "string",
          "description": "Search match snippet from document content (HTML)"
        },
        "title": {
          "type": "string",
          "description": "Search match snippet from document title (HTML)"
        }
      }
    }
  }
}
