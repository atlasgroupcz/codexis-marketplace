{
  "source": "CR",
  "kind": "input",
  "root": "CrSearchRequest",
  "apiDocsUrl": "https://beta.next.codexis.cz/rest/v3/api-docs",
  "fetchedAt": "2026-03-18T09:41:52Z",
  "components": {
    "CrSearchRequest": {
      "type": "object",
      "description": "Search request for Czech legislation (CR)",
      "properties": {
        "sortBy": {
          "type": "string",
          "description": "Sorting option",
          "enum": [
            "DATE",
            "NAME",
            "RELEVANCE"
          ]
        },
        "query": {
          "type": "string",
          "description": "Fulltext search query. Supports space-separated terms, wildcards (*), and phrase search with double quotes. Write Czech characters directly (e.g., `požární ochrana`, `nájem bytu`). Do not use Unicode escapes.",
          "examples": [
            "požární ochrana \"nájem bytu\"",
            "smlouva o dílo",
            "vražda z afektu"
          ],
          "minLength": 1
        },
        "offset": {
          "type": "integer",
          "format": "int32",
          "default": 0,
          "description": "Offset of the first result (0-based)"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "default": 10,
          "description": "Number of results (1-50)"
        },
        "sortOrder": {
          "type": "string",
          "default": "DESC",
          "description": "Sort order for results",
          "enum": [
            "ASC",
            "DESC"
          ]
        },
        "typ": {
          "type": "array",
          "description": "Facet field 'typ'",
          "example": [
            "Zákon",
            "Vyhláška",
            "Nařízení vlády"
          ],
          "items": {
            "type": "string"
          }
        },
        "autor": {
          "type": "array",
          "description": "Facet field 'autor'",
          "example": [
            "Ministerstvo financí",
            "Ministerstvo práce a sociálních věcí"
          ],
          "items": {
            "type": "string"
          }
        },
        "validAt": {
          "type": "string",
          "format": "date",
          "description": "Filter by validity at date (mutually exclusive with validNow)",
          "example": "2023-01-01"
        },
        "validNow": {
          "type": "boolean",
          "description": "Filter only currently valid documents",
          "example": true
        },
        "issuedFrom": {
          "type": "string",
          "format": "date",
          "description": "Issue date from",
          "example": "2021-01-01"
        },
        "issuedTo": {
          "type": "string",
          "format": "date",
          "description": "Issue date to",
          "example": "2023-12-31"
        },
        "effectiveFrom": {
          "type": "string",
          "format": "date",
          "description": "Effective date from",
          "example": "2022-01-01"
        },
        "effectiveTo": {
          "type": "string",
          "format": "date",
          "description": "Effective date to",
          "example": "2024-12-31"
        },
        "approvedFrom": {
          "type": "string",
          "format": "date",
          "description": "Approval date from",
          "example": "2021-01-01"
        },
        "approvedTo": {
          "type": "string",
          "format": "date",
          "description": "Approval date to",
          "example": "2023-12-31"
        },
        "changedFrom": {
          "type": "string",
          "format": "date",
          "description": "Change date from",
          "example": "2023-01-01"
        },
        "changedTo": {
          "type": "string",
          "format": "date",
          "description": "Change date to",
          "example": "2023-12-31"
        }
      },
      "required": [
        "query"
      ]
    }
  }
}
