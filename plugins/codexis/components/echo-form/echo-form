#!/usr/bin/env bash
set -euo pipefail

url_decode() {
  local data="${1//+/ }"
  printf '%b' "${data//%/\\x}"
}

html_escape() {
  local value="$1"
  value="${value//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  value="${value//\"/&quot;}"
  value="${value//\'/&#39;}"
  printf '%s' "$value"
}

extract_form_field() {
  local payload="$1"
  local target_key="$2"
  local pair
  IFS='&' read -r -a pairs <<< "$payload"
  for pair in "${pairs[@]}"; do
    local key="${pair%%=*}"
    local value="${pair#*=}"
    if [[ "$key" == "$target_key" ]]; then
      url_decode "$value"
      return 0
    fi
  done
  printf ''
}

request_method="${REQUEST_METHOD:-GET}"
request_path="${SCRIPT_NAME:-/}"
request_base="$request_path"
if [[ "$request_base" != */ ]]; then
  request_base="$request_base/"
fi
input_value=""

if [[ "$request_method" == "POST" ]]; then
  content_length="${CONTENT_LENGTH:-0}"
  body=""
  if [[ "$content_length" =~ ^[0-9]+$ ]] && (( content_length > 0 )); then
    IFS= read -r -N "$content_length" body || true
  fi
  input_value="$(extract_form_field "$body" "inputText")"
else
  input_value="$(extract_form_field "${QUERY_STRING:-}" "inputText")"
fi

escaped_value="$(html_escape "$input_value")"

printf 'Content-Type: text/html; charset=utf-8\n\n'
cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <base href="$request_base" />
  <title>Echo Form</title>
  <link rel="stylesheet" href="./assets/styles.css" />
  <script defer src="./assets/app.js"></script>
</head>
<body>
  <main class="card">
    <header class="header">
      <img src="./assets/logo.svg" alt="logo" class="logo" />
      <div>
        <h1>Echo Form</h1>
        <p class="subtitle">Generated by component binary. Assets loaded from static files.</p>
      </div>
    </header>

    <section class="images">
      <img src="./assets/banner.png" alt="banner" class="banner" />
      <img src="./assets/icon.png" alt="icon" class="icon" />
    </section>

    <form id="echo-form" class="form" method="POST" action="$request_base" autocomplete="off">
      <input id="inputText" name="inputText" type="text" placeholder="Type something" value="$escaped_value" />
      <button type="submit">Echo</button>
    </form>

    <p class="result">Echo from binary: <strong id="echo-output">$escaped_value</strong></p>
    <pre id="json-preview" class="json"></pre>
  </main>
</body>
</html>
HTML
