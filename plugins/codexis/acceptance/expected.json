{
  "skills": [
    "codexis:codexis",
    "codexis:cdxctl",
    "codexis:sledovana-judikatura",
    "codexis:sledovane-dokumenty"
  ],
  "env_vars": [
    "CODEXIS_PUBLIC_API_URL",
    "CODEXIS_PUBLIC_BASE_URL",
    "CODEXIS_PUBLIC_DAEMON_URL",
    "CODEXIS_USER_API_TOKEN"
  ],
  "post_install": [
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-cli"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-link-rewriter"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-sledovane-dokumenty"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-sledovana-judikatura"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdxctl"
    },
    {
      "type": "dir",
      "path": "$HOME/.local/share/codexis/lib/sledovane_dokumenty_core"
    },
    {
      "type": "dir",
      "path": "$HOME/.local/share/codexis/lib/sledovana_judikatura_core"
    }
  ],
  "post_uninstall": [
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-cli"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-link-rewriter"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-sledovane-dokumenty"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-sledovana-judikatura"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdxctl"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/share/codexis"
    }
  ]
}
