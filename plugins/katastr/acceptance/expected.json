{
  "skills": [
    "katastr:katastr"
  ],
  "env_vars": [
    "CODEXIS_PUBLIC_USER_HOME"
  ],
  "post_install": [
    {
      "type": "file",
      "path": "$HOME/.local/bin/katastr-cli"
    },
    {
      "type": "dir",
      "path": "$HOME/.local/share/katastr/lib/katastr_core"
    }
  ],
  "post_uninstall": [
    {
      "type": "absent",
      "path": "$HOME/.local/bin/katastr-cli"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/share/katastr"
    }
  ]
}
