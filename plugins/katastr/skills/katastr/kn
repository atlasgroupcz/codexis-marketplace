#!/usr/bin/env python3
"""KN API client – thin wrapper around CUZK REST API KN.

Usage:
    ./kn <path>              GET request, print JSON response
    ./kn <path> --raw        GET request, print raw response (no truncation)

Examples:
    ./kn "/api/v1/Parcely/Vyhledani?KodKatastralnihoUzemi=638790&TypParcely=PKN&DruhCislovaniParcely=2&KmenoveCisloParcely=545"
    ./kn "/api/v1/Parcely/12345"
    ./kn "/api/v1/AplikacniSluzby/StavUctu"
"""

import json
import os
import sys
import urllib.request
import urllib.error

BASE = "https://api-kn.cuzk.gov.cz"
MAX_OUTPUT = 4000


def load_api_key():
    env_path = os.path.expanduser("~/.cdx/apps/katastr/.env")
    if not os.path.isfile(env_path):
        return ""
    with open(env_path) as f:
        for line in f:
            if line.startswith("API_KEY="):
                return line.strip().split("=", 1)[1]
    return ""


def kn_get(path):
    api_key = load_api_key()
    if not api_key:
        print("ERROR: API klíč není nastaven. Nastavte ho v Doplňky → Katastr → Nastavení.")
        sys.exit(1)

    url = BASE + path if path.startswith("/") else BASE + "/" + path
    req = urllib.request.Request(url, headers={"ApiKey": api_key, "Accept": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print("ERROR: API klíč pro Katastr je neplatný. Nastavte správný klíč v Doplňky → Katastr → Nastavení.")
            sys.exit(1)
        if e.code == 403:
            print("ERROR: Přístup odepřen (403) pro " + path)
            sys.exit(1)
        print(f"ERROR: HTTP {e.code} pro {path}")
        sys.exit(1)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        sys.exit(0)

    path = sys.argv[1]
    raw = "--raw" in sys.argv

    result = kn_get(path)
    output = json.dumps(result, ensure_ascii=False, indent=2)

    if not raw and len(output) > MAX_OUTPUT:
        print(output[:MAX_OUTPUT])
        print(f"\n... (truncated, {len(output)} chars total; use --raw for full output)")
    else:
        print(output)


if __name__ == "__main__":
    main()
