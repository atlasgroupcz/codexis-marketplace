{
  "endpoint": "meta",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://10.245.1.74:8081/v3/api-docs",
  "fetchedAt": "2026-05-18T00:00:00Z",
  "cdxPatterns": [
    "cdx-nl://doc/<NLBWB_ID>/meta",
    "cdx-nl://law/NL/<BWB_ID>/meta",
    "cdx-nl://afkorting/<ABBR>/meta"
  ],
  "operations": [
    {
      "path": "/api/NL/wetten/bwb/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Retrieve metadata for a BWB document by display ID.",
      "operationId": "getMeta",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "NLBWB1234"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WettenOverheidNlBwbMetaResponse" }
            }
          }
        }
      }
    },
    {
      "path": "/api/NL/wetten/bwb/bwbid/{bwbId}/meta",
      "method": "get",
      "summary": "Get BWB document metadata by source BWB-id",
      "description": "Resolve a BWB document by its source identifier (BWBR / BWBV / BWBW) and return its metadata.",
      "operationId": "getMetaByBwbId",
      "parameters": [
        {
          "name": "bwbId",
          "in": "path",
          "description": "BWB identifier",
          "required": true,
          "schema": { "type": "string" },
          "example": "BWBR0001827"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WettenOverheidNlBwbMetaResponse" }
            }
          }
        }
      }
    },
    {
      "path": "/api/NL/wetten/bwb/afkorting/{afkorting}/meta",
      "method": "get",
      "summary": "Get BWB document metadata by abbreviation",
      "description": "Resolve a BWB document by its common abbreviation (e.g. AWB, BW) and return its metadata.",
      "operationId": "getMetaByAfkorting",
      "parameters": [
        {
          "name": "afkorting",
          "in": "path",
          "description": "BWB abbreviation",
          "required": true,
          "schema": { "type": "string" },
          "example": "AWB"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WettenOverheidNlBwbMetaResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "WettenOverheidNlBwbMetaResponse": {
        "type": "object",
        "description": "Document record metadata for BWB regulations",
        "properties": {
          "docId": { "type": "string", "description": "Document ID", "example": "NLBWB1234" },
          "metadata": {
            "$ref": "#/components/schemas/WettenOverheidNlBwbMetadataResponse",
            "description": "BWB main regulation metadata"
          },
          "assets": {
            "type": "array",
            "description": "Attachments with download URLs (PDFs and XMLs)",
            "items": { "$ref": "#/components/schemas/AssetResponse" }
          }
        }
      },
      "WettenOverheidNlBwbMetadataResponse": {
        "type": "object",
        "description": "BWB main regulation metadata",
        "properties": {
          "url": { "type": "string", "description": "Canonical wetten.overheid.nl URL for the law (no date)" },
          "bwbId": { "type": "string", "description": "BWB identifier", "example": "BWBR0001827" },
          "title": { "type": "string", "description": "Citeertitel of the law" },
          "type": { "type": "string", "description": "BWB type letter (R, V, W)" },
          "regelingSoort": { "type": "string", "description": "Regulation soort" },
          "rechtsgebied": {
            "type": "array",
            "description": "Legal domains",
            "items": { "type": "string" }
          },
          "afkorting": { "type": "string", "description": "Common abbreviation" },
          "datumIntrekking": { "type": "string", "description": "Repeal date (ISO YYYY-MM-DD), null if active" },
          "datumLaatsteWijziging": { "type": "string", "description": "Last amendment date (ISO YYYY-MM-DD)" },
          "issuingAuthority": { "type": "string", "description": "Issuing authority" }
        }
      },
      "AssetResponse": {
        "type": "object",
        "description": "Asset file reference with download URL",
        "properties": {
          "file": { "type": "string", "description": "S3 content filename (use with /attachment/{filename})", "example": "content_1.pdf" },
          "original_name": { "type": "string", "description": "Original filename from source", "example": "bwbr0001827.pdf" },
          "download_url": { "type": "string", "description": "cdx-nl:// link to download this attachment", "example": "cdx-nl://doc/NLBWB1234/attachment/content_1.pdf" }
        }
      }
    }
  }
}
