{
  "endpoint": "related",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://10.245.1.74:8081/v3/api-docs",
  "fetchedAt": "2026-05-18T00:00:00Z",
  "cdxPatterns": [
    "cdx-nl://doc/<NLBWB_ID>/related",
    "cdx-nl://law/NL/<BWB_ID>/related",
    "cdx-nl://afkorting/<ABBR>/related"
  ],
  "operations": [
    {
      "path": "/api/NL/wetten/bwb/doc/{docId}/related",
      "method": "get",
      "summary": "Get related laws",
      "description": "Cross-references between BWB laws, in either direction. direction=in (default): laws that cite THIS one (inverse refs). direction=out: laws cited by THIS one (forward refs from per-timecut relatedBwbIds). Each law surfaces once via collapse on record_id; latest toestand wins.",
      "operationId": "getRelated",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "NLBWB1234"
        },
        {
          "name": "direction",
          "in": "query",
          "description": "in = laws citing this; out = laws this cites",
          "required": false,
          "schema": { "type": "string", "enum": ["in", "out"] }
        },
        {
          "name": "offset",
          "in": "query",
          "description": "Pagination offset (default: 0)",
          "required": false,
          "schema": { "type": "integer", "format": "int32" }
        },
        {
          "name": "limit",
          "in": "query",
          "description": "Page size (default: 20, max: 100)",
          "required": false,
          "schema": { "type": "integer", "format": "int32" }
        }
      ],
      "responses": {
        "200": {
          "description": "Related documents",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RelatedResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "RelatedResponse": {
        "type": "object",
        "description": "Paginated list of related documents",
        "properties": {
          "results": {
            "type": "array",
            "description": "Related documents",
            "items": { "$ref": "#/components/schemas/RelatedItem" }
          },
          "totalResults": { "type": "integer", "format": "int64", "description": "Total number of related documents", "example": 42 },
          "offset": { "type": "integer", "format": "int32", "description": "Pagination offset", "example": 0 },
          "limit": { "type": "integer", "format": "int32", "description": "Page size", "example": 20 }
        }
      },
      "RelatedItem": {
        "type": "object",
        "description": "A related document (may be from a different domain)",
        "properties": {
          "docId": { "type": "string", "description": "Document ID", "example": "NLBWB1234" },
          "domain": { "type": "string", "description": "Source domain/index", "example": "wetten_overheid_nl_bwb" },
          "title": { "type": "string", "description": "Document title" },
          "recordId": { "type": "string", "description": "Record ID" },
          "docUrl": { "type": "string", "description": "Link to document metadata endpoint" },
          "relationType": {
            "type": "string",
            "description": "Relation type",
            "enum": [
              "IMPLEMENTING",
              "AMENDS",
              "AMENDED_BY",
              "REPEALS",
              "REFERENCING_DECISION",
              "REFERENCED_LAW",
              "CITED_LAW",
              "CITING_LAW",
              "CITING_DECISION",
              "RELATED_BGBL",
              "RELATED_DECISION"
            ]
          }
        }
      }
    }
  }
}
