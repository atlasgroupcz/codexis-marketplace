      "operationId": "getMeta_3",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "ATSO1234"
        }
      ],
      "responses": {
