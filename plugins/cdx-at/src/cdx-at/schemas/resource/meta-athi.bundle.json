      "operationId": "getMeta_4",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "ATHI1234"
        }
      ],
      "responses": {
