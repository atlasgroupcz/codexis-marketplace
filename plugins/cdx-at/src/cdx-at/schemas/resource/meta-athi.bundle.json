{
  "endpoint": "meta",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://localhost:8081/v3/api-docs",
  "fetchedAt": "2026-05-27T00:00:00Z",
  "cdxPatterns": [
    "cdx-at://doc/<DOC_ID>/meta"
  ],
  "operations": [
    {
      "path": "/api/AT/history/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Retrieve metadata for an Austrian consolidated federal law norm (Bundesnormen) by document ID. Returns a RisMetaResponse envelope: flat scalar metadata (all array-valued fields plus assets and schemaVersion stripped), relationCounts (a bare map of RelationType -> count), and assets each carrying a download_url.",
      "operationId": "getMeta_4",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "ATHI1234"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata envelope",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RisMetaResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "RisMetaResponse": {
        "type": "object",
        "description": "Metadata envelope for one Austrian consolidated federal law norm (History). Null fields are omitted (NON_NULL).",
        "properties": {
          "docId": { "type": "string", "description": "Display document ID", "example": "ATHI1234" },
          "metadata": { "$ref": "#/components/schemas/RisHistoryMetadataFlat" },
          "relationCounts": { "$ref": "#/components/schemas/RisHistoryRelationCounts" },
          "assets": {
            "type": "array",
            "description": "Attachment files with download URLs",
            "items": { "$ref": "#/components/schemas/AssetResponse" }
          }
        }
      },
      "RisHistoryMetadataFlat": {
        "type": "object",
        "description": "Flat scalar metadata for an Austrian consolidated federal law norm (Bundesnormen). Array-valued fields (indices, note, amendments, annotation, keywords), assets, and schemaVersion are stripped. Null fields are omitted.",
        "properties": {
          "url": { "type": "string", "description": "Source URL" },
          "documentNumber": { "type": "string", "description": "Document number" },
          "application": { "type": "string", "description": "Application" },
          "shortTitle": { "type": "string", "description": "Short title" },
          "title": { "type": "string", "description": "Full title" },
          "eli": { "type": "string", "description": "European Legislation Identifier" },
          "publicationOrgan": { "type": "string", "description": "Publication organ" },
          "documentType": { "type": "string", "description": "Document type" },
          "normType": { "type": "string", "description": "Norm type" },
          "articleParagraph": { "type": "string", "description": "Article/paragraph" },
          "paragraphNumber": { "type": "string", "description": "Paragraph number" },
          "parentPublicationOrgan": { "type": "string", "description": "Parent publication organ" },
          "parentGazetteNumber": { "type": "string", "description": "Parent gazette number" },
          "effectiveDate": { "type": "string", "description": "Effective date" },
          "expiryDate": { "type": "string", "description": "Expiry date" },
          "abbreviation": { "type": "string", "description": "Law abbreviation" },
          "lawNumber": { "type": "string", "description": "Law number (Gesetzesnummer)" },
          "fullLegislationUrl": { "type": "string", "description": "Full legislation URL" },
          "authority": { "type": "string", "description": "Issuing authority" },
          "publishedDate": { "type": "string", "description": "Published date" },
          "lastModified": { "type": "string", "description": "Last modified date" }
        }
      },
      "RisHistoryRelationCounts": {
        "type": "object",
        "description": "Counts of related documents grouped by relation type. Bare map keyed by RelationType enum name; History always emits these keys (0 when none).",
        "properties": {
          "CITING_DECISION": { "type": "integer", "description": "Court decisions citing this law" },
          "RELATED_BGBL": { "type": "integer", "description": "Related BGBl documents (by ELI)" },
          "CITED_LAW": { "type": "integer", "description": "Laws cited in this document (by Gesetzesnummer)" }
        }
      },
      "AssetResponse": {
        "type": "object",
        "description": "Asset file reference with download URL",
        "properties": {
          "file": { "type": "string", "description": "S3 content filename", "example": "content_1.pdf" },
          "original_name": { "type": "string", "description": "Original filename from source" },
          "download_url": { "type": "string", "description": "cdx-at:// link to download this attachment", "example": "cdx-at://doc/ATHI1234/attachment/content_1.pdf" }
        }
      }
    }
  }
}
