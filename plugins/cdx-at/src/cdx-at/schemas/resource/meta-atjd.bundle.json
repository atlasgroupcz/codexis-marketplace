{
  "endpoint": "meta",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://localhost:8081/v3/api-docs",
  "fetchedAt": "2026-05-27T00:00:00Z",
  "cdxPatterns": [
    "cdx-at://doc/<DOC_ID>/meta"
  ],
  "operations": [
    {
      "path": "/api/AT/judikatur/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Retrieve metadata for an Austrian case law document by document ID. Returns a RisMetaResponse envelope: flat scalar metadata (all array-valued fields plus assets and schemaVersion stripped), relationCounts (a bare map of RelationType -> count), and assets each carrying a download_url.",
      "operationId": "getMeta_1",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "ATJD1234"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata envelope",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RisMetaResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "RisMetaResponse": {
        "type": "object",
        "description": "Metadata envelope for one Austrian case law document. Null fields are omitted (NON_NULL).",
        "properties": {
          "docId": { "type": "string", "description": "Display document ID", "example": "ATJD1234" },
          "metadata": { "$ref": "#/components/schemas/RisJudikaturMetadataFlat" },
          "relationCounts": { "$ref": "#/components/schemas/RisJudikaturRelationCounts" },
          "assets": {
            "type": "array",
            "description": "Attachment files with download URLs",
            "items": { "$ref": "#/components/schemas/AssetResponse" }
          }
        }
      },
      "RisJudikaturMetadataFlat": {
        "type": "object",
        "description": "Flat scalar metadata for an Austrian case law record. Array-valued fields (caseNumbers, legalNorms, parsedLegalNorms, indices, legalAreas, legalPrincipleNumbers, references), assets, and schemaVersion are stripped. Null fields are omitted.",
        "properties": {
          "url": { "type": "string", "description": "Source URL" },
          "documentNumber": { "type": "string", "description": "Document number" },
          "application": { "type": "string", "description": "Court application (Vfgh, Vwgh, Justiz, etc.)" },
          "documentType": { "type": "string", "description": "Document type" },
          "decisionDate": { "type": "string", "description": "Decision date" },
          "keywords": { "type": "string", "description": "Keywords" },
          "ecli": { "type": "string", "description": "ECLI identifier" },
          "court": { "type": "string", "description": "Court name" },
          "decisionType": { "type": "string", "description": "Decision type" },
          "headnote": { "type": "string", "description": "Headnote/summary" },
          "state": { "type": "string", "description": "State (for Lvwg)" },
          "lastModified": { "type": "string", "description": "Last modified date" },
          "legalPrincipleNumber": { "type": "string", "description": "Legal principle number" },
          "documentNumberType": { "type": "string", "description": "Document number type" },
          "parentLegalPrincipleNumber": { "type": "string", "description": "Parent legal principle number" },
          "parentLegalPrincipleHint": { "type": "string", "description": "Parent legal principle hint" },
          "note": { "type": "string", "description": "Note" },
          "shortDescription": { "type": "string", "description": "Short description" },
          "decidingAuthority": { "type": "string", "description": "Deciding authority" },
          "shortName": { "type": "string", "description": "Short name" },
          "fullDecisionUrl": { "type": "string", "description": "Full decision URL" },
          "decisionTextUrl": { "type": "string", "description": "Decision text URL" },
          "legalPrinciplesUrl": { "type": "string", "description": "Legal principles URL" },
          "legalPrincipleChainUrl": { "type": "string", "description": "Legal principle chain URL" },
          "decisionTextDocumentNumber": { "type": "string", "description": "Decision text document number" },
          "fullDecisionDocumentNumber": { "type": "string", "description": "Full decision document number" }
        }
      },
      "RisJudikaturRelationCounts": {
        "type": "object",
        "description": "Counts of related documents grouped by relation type. Bare map keyed by RelationType enum name; Judikatur always emits these keys (0 when none).",
        "properties": {
          "CITED_LAW": { "type": "integer", "description": "Laws cited in this decision (by Gesetzesnummer)" },
          "RELATED_BGBL": { "type": "integer", "description": "Related BGBl documents (by ELI)" },
          "RELATED_DECISION": { "type": "integer", "description": "Related court decisions (by document number)" }
        }
      },
      "AssetResponse": {
        "type": "object",
        "description": "Asset file reference with download URL",
        "properties": {
          "file": { "type": "string", "description": "S3 content filename", "example": "content_1.pdf" },
          "original_name": { "type": "string", "description": "Original filename from source" },
          "download_url": { "type": "string", "description": "cdx-at:// link to download this attachment", "example": "cdx-at://doc/ATJD1234/attachment/content_1.pdf" }
        }
      }
    }
  }
}
