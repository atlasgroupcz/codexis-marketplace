{
  "endpoint": "meta",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://localhost:8081/v3/api-docs",
  "fetchedAt": "2026-05-27T00:00:00Z",
  "cdxPatterns": [
    "cdx-at://doc/<DOC_ID>/meta"
  ],
  "operations": [
    {
      "path": "/api/AT/bundesrecht/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Retrieve metadata for an Austrian federal legislation (BGBl) document by document ID. Returns a RisMetaResponse envelope: flat scalar metadata (all array-valued fields plus assets and schemaVersion stripped), relationCounts (a bare map of RelationType -> count), and assets each carrying a download_url.",
      "operationId": "getMeta",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "ATBR1234"
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata envelope",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RisMetaResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "RisMetaResponse": {
        "type": "object",
        "description": "Metadata envelope for one Austrian federal legislation (BGBl) document. Null fields are omitted (NON_NULL).",
        "properties": {
          "docId": { "type": "string", "description": "Display document ID", "example": "ATBR1234" },
          "metadata": { "$ref": "#/components/schemas/RisBundesrechtMetadataFlat" },
          "relationCounts": { "$ref": "#/components/schemas/RisBundesrechtRelationCounts" },
          "assets": {
            "type": "array",
            "description": "Attachment files with download URLs",
            "items": { "$ref": "#/components/schemas/AssetResponse" }
          }
        }
      },
      "RisBundesrechtMetadataFlat": {
        "type": "object",
        "description": "Flat scalar metadata for an Austrian federal legislation (BGBl) record. The array-valued field celexNumbers, assets, and schemaVersion are stripped. Null fields are omitted.",
        "properties": {
          "url": { "type": "string", "description": "Source URL" },
          "documentNumber": { "type": "string", "description": "Document number" },
          "shortTitle": { "type": "string", "description": "Short title" },
          "title": { "type": "string", "description": "Full title" },
          "gazetteNumber": { "type": "string", "description": "Gazette number (BGBl)" },
          "part": { "type": "string", "description": "BGBl part (I, II, III)" },
          "publicationDate": { "type": "string", "description": "Publication date" },
          "documentType": { "type": "string", "description": "Document type" },
          "authority": { "type": "string", "description": "Issuing authority" },
          "submitter": { "type": "string", "description": "Submitter" },
          "eli": { "type": "string", "description": "European Legislation Identifier" },
          "legislativePeriod": { "type": "string", "description": "Legislative period" },
          "nationalCouncilDate": { "type": "string", "description": "National council date" },
          "nationalCouncilSession": { "type": "string", "description": "National council session" },
          "governmentProposal": { "type": "string", "description": "Government proposal" },
          "nationalCouncilCommitteeReport": { "type": "string", "description": "National council committee report" },
          "federalCouncilDate": { "type": "string", "description": "Federal council date" },
          "federalCouncilSession": { "type": "string", "description": "Federal council session" },
          "federalCouncilCommitteeReport": { "type": "string", "description": "Federal council committee report" }
        }
      },
      "RisBundesrechtRelationCounts": {
        "type": "object",
        "description": "Counts of related documents grouped by relation type. Bare map keyed by RelationType enum name; Bundesrecht always emits these keys (0 when none).",
        "properties": {
          "CITED_LAW": { "type": "integer", "description": "Laws cited in this document (by Gesetzesnummer)" },
          "RELATED_BGBL": { "type": "integer", "description": "Related BGBl documents (by ELI)" }
        }
      },
      "AssetResponse": {
        "type": "object",
        "description": "Asset file reference with download URL",
        "properties": {
          "file": { "type": "string", "description": "S3 content filename", "example": "content_1.pdf" },
          "original_name": { "type": "string", "description": "Original filename from source" },
          "download_url": { "type": "string", "description": "cdx-at:// link to download this attachment", "example": "cdx-at://doc/ATBR1234/attachment/content_1.pdf" }
        }
      }
    }
  }
}
