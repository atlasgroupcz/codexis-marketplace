{
  "skills": [
    "cdx-at:cdx-at"
  ],
  "env_vars": [
    "CODEXIS_PUBLIC_AT_API_URL",
    "CODEXIS_USER_API_TOKEN"
  ],
  "post_install": [
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-at"
    },
    {
      "type": "file",
      "path": "$HOME/.local/bin/cdx-at-link-rewriter"
    }
  ],
  "post_uninstall": [
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-at"
    },
    {
      "type": "absent",
      "path": "$HOME/.local/bin/cdx-at-link-rewriter"
    }
  ]
}
