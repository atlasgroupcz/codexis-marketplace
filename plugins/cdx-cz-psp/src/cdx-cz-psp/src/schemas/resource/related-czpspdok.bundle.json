          "limit": { "type": "integer", "format": "int32", "description": "Page size" }
        }
      },
      "PspCzDokumentyRelatedItem": {
        "type": "object",
        "description": "Referenced law item",
        "properties": {
          "lawId": { "type": "string", "description": "Law identifier/reference" }
        }
      }
    }
  }
