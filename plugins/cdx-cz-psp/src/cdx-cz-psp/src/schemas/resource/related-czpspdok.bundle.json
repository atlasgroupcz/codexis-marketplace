  "operations": [
    {
      "path": "/api/CZ/psp/dokumenty/doc/{docId}/related",
      "method": "get",
      "summary": "Get referenced laws",
      "description": "Retrieve laws referenced in a parliamentary document.",
      "operationId": "getDokumentyRelated",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "CZPSPDOK1234"
        },
        {
          "name": "offset",
          "in": "query",
          "description": "Pagination offset (default: 0)",
          "required": false,
          "schema": { "type": "integer", "format": "int32" }
        },
        {
          "name": "limit",
          "in": "query",
          "description": "Page size (default: 20, max: 100)",
          "required": false,
          "schema": { "type": "integer", "format": "int32" }
        }
      ],
      "responses": {
        "200": {
          "description": "Referenced laws",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PspCzDokumentyRelatedResponse" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "PspCzDokumentyRelatedResponse": {
        "type": "object",
        "description": "Referenced laws response",
        "properties": {
          "results": {
            "type": "array",
