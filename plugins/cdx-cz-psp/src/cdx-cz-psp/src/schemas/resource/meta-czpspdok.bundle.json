{
  "endpoint": "meta",
  "kind": "resource",
  "format": "openapi-fragment",
  "apiDocsUrl": "http://localhost:8081/v3/api-docs",
  "fetchedAt": "2026-04-01T00:00:00Z",
  "cdxPatterns": [
    "cdx-cz-psp://doc/<DOC_ID>/meta"
  ],
  "operations": [
    {
      "path": "/api/CZ/psp/dokumenty/doc/{docId}/meta",
      "method": "get",
      "summary": "Get document metadata",
      "description": "Retrieve metadata for a Czech Parliament document (reports, interpellations, EU docs) by document ID.",
      "operationId": "getMeta",
      "parameters": [
        {
          "name": "docId",
          "in": "path",
          "description": "Document ID",
          "required": true,
          "schema": { "type": "string" },
          "example": "CZPSPDOK1234"
        },
        {
          "name": "includeAllAssets",
          "in": "query",
          "description": "If true, return all assets; if false (default), return only the primary content files (content_1.pdf and content_1.docx). Some documents have 50+ assets.",
          "required": false,
          "schema": { "type": "boolean" }
        }
      ],
      "responses": {
        "200": {
          "description": "Document metadata",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PspCzDokumentyMetadata" }
            }
          }
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "PspCzDokumentyMetadata": {
        "type": "object",
        "description": "Metadata for Czech Parliament documents (reports, interpellations, EU docs)",
        "properties": {
          "docId": { "type": "string", "description": "Document ID" },
          "title": { "type": "string", "description": "Short title" },
          "fullTitle": { "type": "string", "description": "Full title" },
          "documentType": { "type": "string", "description": "Document type (e.g. Písemná interpelace, Zpráva a jiné)" },
          "electionPeriod": { "type": "integer", "description": "Election period number" },
          "pressNumber": { "type": "string", "description": "Print/press number" },
          "author": { "type": "string", "description": "Author name" },
          "submissionDate": { "type": "string", "description": "Submission date" },
          "currentState": { "type": "string", "description": "Current state text" },
          "stateClass": { "type": "string", "description": "State class (approved, unapproved, lightgray, in_progress)" },
          "addressee": { "type": "string", "description": "Interpellation addressee" },
          "filingDate": { "type": "string", "description": "Filing date (interpellations)" },
          "sentDate": { "type": "string", "description": "Date sent to addressee (interpellations)" },
          "schedulingRequestDate": { "type": "string", "description": "Scheduling request date (interpellations)" },
          "votingResult": { "type": "string", "description": "Voting result (interpellations)" },
          "committee": { "type": "string", "description": "Assigned committee (reports)" },
          "committeeResult": { "type": "string", "description": "Committee resolution (reports)" },
          "euCommittee": { "type": "string", "description": "EU reviewing committee" },
          "odokUrl": { "type": "string", "description": "eKLEP/ODOK reference URL" },
          "subPrints": {
            "type": "array",
            "description": "Sub-prints/documents",
            "items": { "$ref": "#/components/schemas/SubPrint" }
          },
          "assets": {
            "type": "array",
            "description": "Attachments",
            "items": { "$ref": "#/components/schemas/Asset" }
          }
        }
      },
      "SubPrint": {
        "type": "object",
        "properties": {
          "printNumber": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "url": { "type": "string" },
          "pdfUrl": { "type": "string" }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "file": { "type": "string", "description": "Internal filename" },
          "originalName": { "type": "string", "description": "Original filename from source" }
        }
      }
    }
  }
}
